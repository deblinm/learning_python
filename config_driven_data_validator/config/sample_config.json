{
    "env": "PROD",
    "allowed_countries": [
        "US",
        "CA",
        "MXC"
    ],
    "rules": {
        "age": {
            "type": "age_range",
            "column": "age",
            "min": 18,
            "max": 60,
            "severity": "high"
        },
        "salary": {
            "type": "min_sal",
            "column": "salary",
            "min": 0,
            "severity": "medium"
    },
        "country": {
            "type": "allowed_country",
            "column": "country",
            "allowed_key": "allowed_countries",
            "severity": "low"
        }
    }
}